From 0b62313097f6ee0a05f64bf86d36a174a346f8fd Mon Sep 17 00:00:00 2001
From: Sanchayan Maity <sanchayan@centricular.com>
Date: Thu, 21 May 2026 19:05:51 +0530
Subject: [PATCH 4/5] openssl: Guard some more member accesses with mutex

---
 tls/openssl/gtlsclientconnection-openssl.c | 10 ++++++++++
 tls/openssl/gtlsserverconnection-openssl.c | 19 ++++++++++++++++---
 2 files changed, 26 insertions(+), 3 deletions(-)

diff --git a/tls/openssl/gtlsclientconnection-openssl.c b/tls/openssl/gtlsclientconnection-openssl.c
index 8bdd4692..c321b03b 100644
--- a/tls/openssl/gtlsclientconnection-openssl.c
+++ b/tls/openssl/gtlsclientconnection-openssl.c
@@ -115,6 +115,8 @@ g_tls_client_connection_openssl_get_property (GObject    *object,
   GList *accepted_cas;
   gint i;
 
+  g_tls_connection_openssl_lock (G_TLS_CONNECTION_OPENSSL (object));
+
   switch (prop_id)
     {
     case PROP_VALIDATION_FLAGS:
@@ -169,6 +171,8 @@ g_tls_client_connection_openssl_get_property (GObject    *object,
     default:
       G_OBJECT_WARN_INVALID_PROPERTY_ID (object, prop_id, pspec);
     }
+
+  g_tls_connection_openssl_unlock (G_TLS_CONNECTION_OPENSSL (object));
 }
 
 static void
@@ -180,6 +184,8 @@ g_tls_client_connection_openssl_set_property (GObject      *object,
   GTlsConnectionBase *tls = G_TLS_CONNECTION_BASE (object);
   GTlsClientConnectionOpenssl *openssl = G_TLS_CLIENT_CONNECTION_OPENSSL (object);
 
+  g_tls_connection_openssl_lock (G_TLS_CONNECTION_OPENSSL (object));
+
   switch (prop_id)
     {
     case PROP_VALIDATION_FLAGS:
